<resources xmlns:tools="http://schemas.android.com/tools">
    <!--
        Base app theme. Inherits from Theme.Material3.DayNight.NoActionBar.
        The NoActionBar parent is required since we use a custom Compose TopBar —
        we don't want the XML ActionBar to appear on top of it.
        All colour/typography tokens are overridden by the Compose MaterialTheme.
    -->
    <style name="Theme.PharmaCare" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Status bar is transparent so the Compose gradient header fills it -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLayoutInDisplayCutoutMode" tools:targetApi="o_mr1">shortEdges</item>
    </style>
</resources>
