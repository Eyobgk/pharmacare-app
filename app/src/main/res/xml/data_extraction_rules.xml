<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Excludes the Room database file from cloud backups to avoid restoring
    potentially stale or incompatible database schemas.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="pharmacare_database"/>
        <exclude domain="database" path="pharmacare_database-shm"/>
        <exclude domain="database" path="pharmacare_database-wal"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="pharmacare_database"/>
    </device-transfer>
</data-extraction-rules>
